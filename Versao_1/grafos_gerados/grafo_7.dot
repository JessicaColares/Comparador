digraph GrafoFluxo_7 {
    node [shape=box, style=filled, fillcolor=lightblue];
    edge [color=blue];
    
    // Nós do grafo de fluxo
    N0 [label="Início"];
    N1 [label="if 1"];
    N2 [label="while 1"];
    N3 [label="Processo"];
    N4 [label="Processo"];
    N5 [label="Processo"];
    N6 [label="Processo"];
    N7 [label="Fim"];
    
    // Transições
    N0 -> N1;
    N1 -> N2;
    N2 -> N3;
    N3 -> N4;
    N4 -> N5;
    N5 -> N6;
    N6 -> N7;
    N1 -> N2 [label="loop", color=red];
